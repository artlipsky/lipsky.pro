---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/astro/Logo.astro";
---

<style>
  .hero-title,
  .hero-sub {
    opacity: 0;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-fill-mode: forwards;
  }
  .hero-title {
    animation-name: hero-rise;
    animation-duration: 1.2s;
    animation-delay: 0.8s;
  }
  .hero-sub {
    animation-name: hero-rise;
    animation-duration: 1.2s;
    animation-delay: 1.05s;
  }

  @keyframes hero-rise {
    0% {
      opacity: 0;
      transform: translateY(14px);
      filter: blur(6px);
    }
    60% {
      filter: blur(0);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title,
    .hero-sub {
      animation: none;
      opacity: 1;
      transform: none;
      filter: none;
    }
  }
</style>

<Layout>
  <main class="flex flex-col justify-center items-center gap-10 p-8 min-h-screen text-center">
    <div class="w-40 sm:w-56 md:w-60">
      <Logo />
    </div>
    <div class="flex flex-col gap-4 max-w-2xl">
      <h1
        class="hero-title font-semibold text-3xl md:text-4xl text-balance"
      >
        The greatest developer, designer, and musician
      </h1>
      <p
        class="hero-sub text-muted text-base md:text-lg text-balance"
      >
        Also the most humble.
      </p>
    </div>
  </main>
</Layout>
