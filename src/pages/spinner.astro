---
import Layout from "../layouts/Layout.astro";
import BackLink from "../components/astro/BackLink.astro";
import { SpinnerStage } from "../components/react/Spinner";
---

<Layout
  title="Spinner — pick a name at random"
  description="A spinning wheel of names. Press the button to let chance decide."
>
  <main class="flex flex-col justify-center items-center gap-12 p-4 md:p-8 min-h-screen">
    <div class="flex flex-col items-center gap-3 max-w-2xl text-center">
      <h1 class="font-semibold text-3xl md:text-5xl text-balance">APPS Team</h1>
      <p class="text-muted text-sm md:text-base text-balance">
        Press Spin and let the arrow choose today's MC.
      </p>
    </div>

    <SpinnerStage client:load />

    <BackLink />
  </main>
</Layout>
